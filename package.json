{
  "name": "mc-bedrock-lib",
  "version": "0.2.4",
  "main": "dist/mc-bedrock-lib.js",
  "types": "dist/mc-bedrock-lib.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/mc-bedrock-lib.js --format=esm --external:@minecraft/server --external:@minecraft/server-ui && npm run types && node scripts/patch-dts.js",
    "dev": "nodemon --watch src --ext js,ts --exec \"npm run build\"",
    "types": "dts-bundle-generator -o dist/mc-bedrock-lib.d.ts --project tsconfig.json --no-check src/index.ts",
    "release": "standard-version"
  },
  "description": "Utility library for Minecraft Bedrock API",
  "keywords": [
    "minecraft",
    "bedrock",
    "utility",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "dts-bundle-generator": "^5.9.0",
    "esbuild": "^0.25.10",
    "nodemon": "^3.1.10",
    "standard-version": "^9.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@minecraft/server": "^2.2.0",
    "@minecraft/server-ui": "^2.0.0"
  }
}
